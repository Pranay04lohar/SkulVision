# ============================================================
# SkulVision Backend — Environment Configuration
# Copy this file to .env and adjust values for your setup.
# ============================================================

# --- Application ---
APP_NAME="SkulVision Backend"
VERSION="0.1.0"
HOST="0.0.0.0"
PORT=8000
DEBUG=false
LOG_LEVEL="INFO"

# --- Inference Device ---
# Options: cpu | cuda | mps
DEVICE="cpu"
NUM_INFERENCE_THREADS=4

# --- Object Detection ---
YOLO_MODEL_PATH="models/yolov8n.onnx"
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_NMS_THRESHOLD=0.45
YOLO_INPUT_WIDTH=640
YOLO_INPUT_HEIGHT=640
DETECTION_ENABLED=true

# --- OCR ---
# Options: easyocr | paddleocr
OCR_ENGINE="easyocr"
OCR_LANGUAGES="en"
OCR_ENABLED=true
OCR_MIN_CONFIDENCE=0.5

# --- Streaming ---
MAX_FRAME_DIMENSION=1280
TARGET_FPS=20
FRAME_QUEUE_SIZE=5
JPEG_QUALITY=85

# --- HUD / Overlay ---
OVERLAY_ALPHA=0.7
OVERLAY_FONT_SCALE=0.6
OVERLAY_THICKNESS=2
HUD_SHOW_FPS=true
HUD_SHOW_INFERENCE_TIME=true
