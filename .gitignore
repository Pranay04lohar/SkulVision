# ============================================================
# SkulVision — .gitignore
# ============================================================

# Environment
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
.conda/

# AI Models (large binary files — manage separately)
models/*.onnx
models/*.tflite
models/*.pt
models/*.pth
models/*.bin
models/*.pb
!models/.gitkeep

# EasyOCR model cache
.EasyOCR/

# Test cache
.pytest_cache/
.coverage
htmlcov/
*.xml

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Temporary
tmp/
temp/
*.tmp

# Mobile (Expo / React Native)
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/.env
